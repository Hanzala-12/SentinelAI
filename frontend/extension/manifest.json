{
  "manifest_version": 3,
  "name": "PhishLens Browser Security Copilot",
  "version": "0.1.0",
  "description": "Real-time browser security warnings powered by PhishLens.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishLens"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": ["http://localhost:8000/*", "https://*/*", "http://*/*"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {}
}
