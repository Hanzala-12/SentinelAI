# Backend
APP_NAME=SentinelAI
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
DATABASE_URL=postgresql+psycopg2://sentinelai:sentinelai@postgres:5432/sentinelai
REDIS_URL=redis://redis:6379/0
SENTINELAI_URL_MODEL_URL=https://github.com/faizann24/Phishing-URL-Detection/raw/master/classifier/phishing.pkl
SENTINELAI_MODEL_CACHE_DIR=/var/cache/sentinelai
SENTINELAI_NLP_MODEL=distilbert-base-uncased-finetuned-sst-2-english
HF_HOME=/var/cache/hf
REASON_WEIGHT_PHISHING_PROBABILITY=0.30
REASON_WEIGHT_DOM_SUSPICION=0.25
REASON_WEIGHT_CONTENT_SCAM_SCORE=0.20
REASON_WEIGHT_REPUTATION_SCORE=0.15
REASON_WEIGHT_REDIRECT_RISK=0.10
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_APP_NAME=SentinelAI

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Optional threat intelligence keys
VIRUSTOTAL_API_KEY=
URLSCAN_API_KEY=
ABUSEIPDB_API_KEY=
